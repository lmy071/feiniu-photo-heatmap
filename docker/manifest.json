{
  "name": "feiniu-photo-heatmap",
  "version": "1.0.0",
  "title": "飞牛照片热力图",
  "description": "扫描飞牛 NAS 照片目录，生成 GitHub 风格的每日照片数量热力图",
  "author": {
    "name": "lmy",
    "email": "lmy071@icoud.com"
  },
  "architecture": ["amd64", "arm64"],
  "homepage": "https://github.com/lmy071/feiniu-photo-heatmap",
  "icon": "icon.png",
  "screenshots": ["screenshot.png"],
  "categories": ["工具", "相册"],
  "min_fnos_version": "1.0.0",
  "requirements": {
    "docker": true
  },
  "settings": [
    {
      "key": "SCAN_PATHS",
      "label": "照片扫描路径",
      "description": "飞牛 NAS 上的照片目录，多个路径用逗号分隔。默认从 /volume1/photo 或 /vol1/1000/Photo 挂载",
      "type": "string",
      "default": "/photos",
      "required": true
    },
    {
      "key": "PORT",
      "label": "Web 端口",
      "description": "Web 服务端口",
      "type": "number",
      "default": 3000,
      "required": false
    }
  ],
  "ports": [
    {
      "container": 3000,
      "host": 3000,
      "protocol": "tcp",
      "description": "Web 服务端口"
    }
  ],
  "volumes": [
    {
      "host": "/vol1/1000/Photo",
      "container": "/photos",
      "mode": "ro",
      "description": "飞牛相册目录"
    }
  ],
  "networks": ["default"]
}
