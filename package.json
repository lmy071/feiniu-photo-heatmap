{
  "name": "feiniu-photo-heatmap",
  "version": "1.0.0",
  "description": "飞牛相册照片热力图 - 类似 GitHub 提交热力图",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "docker:build": "docker build -t feiniu-photo-heatmap ./docker",
    "docker:run": "docker run -d -p 3000:3000 --name feiniu-photo-heatmap feiniu-photo-heatmap"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "date-fns": "^3.3.1",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "typescript": "^5.4.2",
    "vite": "^5.1.6",
    "vue-tsc": "^2.0.6"
  }
}
